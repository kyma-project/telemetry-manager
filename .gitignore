.env.overrides

# Finder .DS_Store file
.DS_Store

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
**/bin
testbin/*
artifacts/*
junit.xml

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Kubernetes Generated files - skip generated files, except for vendored files

!vendor/**/zz_generated.*

# editor and IDE paraphernalia
.idea
.fleet
.zed
*.swp
*.swo
*~

# Test certificates for webhook
tls.crt
tls.csr
tls.key

.claude
CLAUDE.local.md

dependencies/sample-app/vendor
dependencies/mock-backend/mock-backend
.vscode

# PR review loop (Claude skill) — local reviewer/implementer hand-off; never commit
.pr-review-loop/
review-loop.diff
review-loop.bak.diff

# Local GitHub Actions logs (downloaded for analysis, not for version control)
gh-logs/
